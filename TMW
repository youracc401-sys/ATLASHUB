local Ring = {}

for i = 1,10 do

    local Dot = Instance.new("Frame")

    local ang = math.rad(i * 36)

    Dot.Size = UDim2.new(0,8,0,8)

    Dot.Position = UDim2.new(
        0.5,
        math.cos(ang) * 38,
        0.5,
        math.sin(ang) * 38
    )

    Dot.BackgroundColor3 = Color3.fromRGB(130,70,255)
    Dot.BorderSizePixel = 0
    Dot.Parent = Loader

    corner(Dot,20)

    table.insert(Ring,Dot)
end

local spinning = false

local function startSpin()

    spinning = true

    task.spawn(function()

        local index = 1

        while spinning do

            for i,d in ipairs(Ring) do

                local active = i == index

                tween(
                    d,
                    {
                        Size = active and UDim2.new(0,14,0,14) or UDim2.new(0,8,0,8),
                        BackgroundTransparency = active and 0 or 0.55
                    },
                    0.08
                ):Play()
            end

            index += 1

            if index > #Ring then
                index = 1
            end

            task.wait(0.05)
        end
    end)
end

local function stopSpin()
    spinning = false
end

