Card.MouseButton1Click:Connect(function()

    Loader.Visible = true

    startSpin()

    task.spawn(function()

        local pct = 0

        while pct < 100 do

            pct += math.random(2,5)

            if pct > 100 then
                pct = 100
            end

            Percent.Text = pct .. "%"

            if pct >= 20 then
                Status.Text = "Connecting..."
            end

            if pct >= 50 then
                Status.Text = "Injecting..."
            end

            if pct >= 80 then
                Status.Text = "Launching..."
            end

            task.wait(0.05)
        end

        stopSpin()

        Percent.Text = "✔"
        Status.Text = "Loaded Successfully"

        for _,d in pairs(Ring) do
            tween(
                d,
                {
                    BackgroundColor3 = Color3.fromRGB(50,255,120),
                    Size = UDim2.new(0,12,0,12)
                },
                0.2
            ):Play()
        end

        local ok,err = executeScript(SCRIPTS[1].url)

        if not ok then

            Percent.Text = "✕"
            Status.Text = "Load Failed"

            warn(err)
        end

        task.wait(0.8)

        Loader.Visible = false

        -- AUTO CLOSE HUB
        tween(
            Hub,
            {
                Size = UDim2.new(0,HUB_W,0,0),
                BackgroundTransparency = 1
            },
            0.35,
            Enum.EasingStyle.Back,
            Enum.EasingDirection.In
        ):Play()

        task.wait(0.4)

        SG:Destroy()
    end)
end)
